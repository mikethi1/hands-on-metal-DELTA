{
  "_comment": "hands-on-metal partition naming index",
  "_version": "2.1.0",
  "_updated": "2026-04-17",
  "_description": "Versioned offline index of known partition naming patterns, device families, and Android version profiles. Used to determine correct install path before a run.",
  "partition_types": {
    "boot": {
      "description": "Standard Android boot partition (ramdisk + kernel). Patched by Magisk on API <= 32 or when init_boot is absent.",
      "magisk_patch_target": true,
      "common_names": [
        "boot",
        "boot_a",
        "boot_b"
      ],
      "image_magic": "ANDROID!",
      "typical_size_mb": [
        32,
        64,
        128
      ]
    },
    "init_boot": {
      "description": "Generic ramdisk partition introduced in Android 13 (API 33). Contains init only; kernel stays in boot. Magisk patches this on API 33+.",
      "magisk_patch_target": true,
      "api_level_min": 33,
      "common_names": [
        "init_boot",
        "init_boot_a",
        "init_boot_b"
      ],
      "image_magic": "ANDROID!",
      "typical_size_mb": [
        8,
        16,
        32
      ]
    },
    "vendor_boot": {
      "description": "Vendor-specific ramdisk (API 30+, GKI 2.0). Not patched by Magisk but listed for reference.",
      "magisk_patch_target": false,
      "api_level_min": 30,
      "common_names": [
        "vendor_boot",
        "vendor_boot_a",
        "vendor_boot_b"
      ],
      "image_magic": "VNDRBOOT",
      "typical_size_mb": [
        32,
        64
      ]
    },
    "recovery": {
      "description": "Dedicated recovery partition (non-A/B devices). Not present on A/B devices where recovery ramdisk is embedded in boot/vendor_boot.",
      "magisk_patch_target": false,
      "common_names": [
        "recovery",
        "recovery_a",
        "recovery_b"
      ],
      "image_magic": "ANDROID!",
      "typical_size_mb": [
        32,
        64,
        128
      ]
    },
    "super": {
      "description": "Dynamic partition container (Android 10+). Contains system, vendor, product, odm as logical partitions.",
      "magisk_patch_target": false,
      "api_level_min": 29,
      "common_names": [
        "super"
      ],
      "typical_size_mb": [
        2048,
        4096,
        8192
      ]
    },
    "vbmeta": {
      "description": "AVB vbmeta image. Contains verification metadata for boot chain. Magisk optionally patches this.",
      "magisk_patch_target": false,
      "common_names": [
        "vbmeta",
        "vbmeta_a",
        "vbmeta_b",
        "vbmeta_system",
        "vbmeta_vendor"
      ],
      "typical_size_mb": [
        1,
        4
      ]
    },
    "dtbo": {
      "description": "Device-tree blob overlay partition. Contains SoC and board device-tree patches.",
      "magisk_patch_target": false,
      "api_level_min": 28,
      "common_names": [
        "dtbo",
        "dtbo_a",
        "dtbo_b"
      ],
      "typical_size_mb": [
        8,
        16,
        32
      ]
    }
  },
  "by_name_paths": [
    "/dev/block/bootdevice/by-name/{name}",
    "/dev/block/by-name/{name}",
    "/dev/block/platform/*/by-name/{name}",
    "/dev/block/platform/*/*/by-name/{name}",
    "/dev/block/mapper/{name}"
  ],
  "android_version_profiles": {
    "api_21_22": {
